import v.builtins.print.*;

#DeriveStructDrop
struct Point {
  x int;
  y! int;
}

interface IShape {
  func area(virtual self &IShape) float;
}

impl IShape for Point;

exported func main() int {
  p = Point(1, 2);
  set p.y = 3;
  msg = "Point x={p.x} y={p.y}";
  if (p.x == 1 and p.y == 3) {
    return 0;
  } else {
    return 1;
  }
}
