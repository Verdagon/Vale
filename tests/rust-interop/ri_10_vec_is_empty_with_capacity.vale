// expected_exit: 1
// summary: is_empty() distinguishes len from capacity — with_capacity(10) still empty since
// nothing has been pushed. Confirms test 05's claim from a different angle (bool return).

import rust.std.vec.Vec;

exported func main() int {
  v = Vec<int>.with_capacity(10i64);
  if (v.is_empty()) {
    return 1;
  }
  return 0;
}
