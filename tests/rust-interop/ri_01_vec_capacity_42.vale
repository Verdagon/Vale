// expected_exit: 42
// summary: Vec::with_capacity(42) then Vec::capacity() should return 42.
// This is the original smoke test from edb294c0a, kept as the baseline.

import rust.std.vec.Vec;

exported func main() int {
  v = Vec<int>.with_capacity(42i64);
  return v.capacity().TruncateI64ToI32();
}
