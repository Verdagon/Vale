// expected_exit: 0
// expected_stdout: "length:\n42\n"
// include_stdlib: true
// summary: Catter's actual main.vale, verbatim. Catter is the original 2024 Vale-to-Rust
// interop proof of concept (vendored at /Catter/). It imports both rust.std.option.Option
// AND rust.std.vec.Vec, allocates Vec<int>.with_capacity(42), prints "length:" then the
// capacity. This test exercises the FULL Catter program — stdlib + extern struct +
// println(i64) + rust interop — which is more than any other ri_* test covers. Kept
// in sync with Catter/src/main.vale.

import rust.std.option.Option;
import rust.std.vec.Vec;

exported func main() {
	vec = Vec<int>.with_capacity(42i64);
	println("length:");
	println(vec.capacity());
}


// TODO: move to standard library
func println(i i64) {
  println(castI64Str(i));
}
func print(i i64) {
  print(castI64Str(i));
}
