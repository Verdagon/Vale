import array.make.*;
import math.*;
import list.*;


struct IntHasher { }
// TSUGAR: func __call(this &IntHasher, x int) int { return x; }
func __call(this &IntHasher, x &int) int { return __copy_prim(x); }

struct IntEquator { }
// TSUGAR: func __call(this &IntEquator, a int, b int) bool { return a == b; }
func __call(this &IntEquator, a &int, b &int) bool { return a == b; }

#!DeriveStructDrop
struct HashMapNode<K Ref, V>
where func drop(K)void, func drop(V)void {
  key K;
  value V;
}
func drop<K Ref, V>(self HashMapNode<K, V>) {
  destruct ^self;
}

#!DeriveStructDrop
struct HashMap<K Ref, V, H, E>
where func(&H, &K)int, func(&E, &K, &K)bool, func drop(K)void, func drop(V)void {
  hasher H;
  equator E;
  table Array<Opt<HashMapNode<K, V>>>;
  size int;
}

func drop<K Ref, V, H, E>(self HashMap<K Ref, V, H, E>)
where func drop(H)void, func drop(E)void {
  destruct ^self;
}

func HashMap<K Ref, V, H, E>(hasher H, equator E) HashMap<K, V, H, E>
where func(&H, &K)int, func(&E, &K, &K)bool {
  return HashMap<K, V, H, E>(^hasher, ^equator, 0);
}

func HashMap<K Ref, V, H, E>(hasher H, equator E, capacity int) HashMap<K, V, H, E>
where func(&H, &K)int, func(&E, &K, &K)bool {
  return HashMap<K, V>(
      ^hasher,
      ^equator,
      Array<Opt<HashMapNode<K, V>>>(capacity),
      0);
}

// TSUGAR: func len<K Ref, V, H, E>(self &HashMap<K, V, H, E>) int { return self.size; }
func len<K Ref, V, H, E>(self &HashMap<K, V, H, E>) int { return __copy_prim(&self.size); }

func update<K Ref, V, H, E>(self &HashMap<K, V, H, E>, key K, value V) V {
  // TSUGAR:   hash int = (&self.hasher)(key);
  hash int = (&self.hasher)(&key);
  // TSUGAR:   startIndex = abs(hash mod (&self.table).len());
  startIndex = abs(&(hash mod (&self.table).len()));
  maybeIndex = findIndexOfKey(&self.table, &self.equator, startIndex, &key);
  if ((&maybeIndex).isEmpty()) {
    panic("Map doesnt have given key!");
  }
  optNode &Opt<HashMapNode<K, V>> = &self.table[(^maybeIndex).get()];
  node &HashMapNode<K, V> = get(&optNode);
  return set node.value = ^value;
}

func add<K Ref, V, H, E>(map &HashMap<K, V, H, E>, key K, value V) void {
  if ((&map).has(&key)) {
    panic("Map already has given key!");
  }
  if ((map.size + 1) * 2 >= (&map.table).len()) {
    newSize =
        if ((&map.table).len() == 0) { 2 }
        else { (&map.table).len() * 2 };
    newTable =
        Array<Opt<HashMapNode<K, V>>>(
            newSize,
            &(index) => {
              opt Opt<HashMapNode<K, V>> = None<HashMapNode<K, V>>();
              ^opt
            });
    i = 0;
    while (i < (&map.table).len()) {
      // TSUGAR:       if (map.table[i].isEmpty()) {
      if ((&(&map.table)[__copy_prim(&i)]).isEmpty()) {
        // do nothing
      } else {
        // TSUGAR:         maybeNode = (set map.table[i] = None<HashMapNode<K, V>>());
        maybeNode = (set map.table[__copy_prim(&i)] = None<HashMapNode<K, V>>());
        node = get(^maybeNode);
        addNodeToTable(&newTable, &map.hasher, ^node);
      }
      set i = i + 1;
    }
    oldTable = set map.table = ^newTable;
    drop_into(^oldTable, &{ (^_).expect_none(); });
  }

  addNodeToTable(&map.table, &map.hasher, HashMapNode<K, V>(^key, ^value));
  set map.size = map.size + 1;
}

// Returns void
func panicVoid<T>(x T) {
  __vbi_panic();
}

func addNodeToTable<K Ref, V, H>(
    table &Array<Opt<HashMapNode<K, V>>>,
    hasher &H,
    node HashMapNode<K, V>)
where func(&H, &K)int, func drop(K)void, func drop(V)void
{
  // TSUGAR:   hash int = (&hasher)(node.key);
  hash int = (&hasher)(&node.key);
  // TSUGAR:   startIndex = abs(hash mod table.len());
  startIndex = abs(&(hash mod table.len()));
  index = findEmptyIndexForKey(&table, startIndex, &node.key);

  opt Opt<HashMapNode<K, V>> = Some(^node);
  // TSUGAR:   (set table[index] = opt).expect_none();
  (set table[__copy_prim(&index)] = ^opt).expect_none();
}

func findEmptyIndexForKey<K Ref, V>(table &Array<Opt<HashMapNode<K, V>>>, startIndex int, key &K) int
where func drop(K)void, func drop(V)void {
  i = 0;
  while (i < table.len()) {
    index = (startIndex + i) mod table.len();
    // TSUGAR:     something = table[index];
    something = &table[__copy_prim(&index)];
    if (something.isEmpty()) {
      return index;
    }
    // continue to next node
    set i = i + 1;
  }
  return panic("findEmptyIndexForKey went past end of table!");
}

func findIndexOfKey<K Ref, V, E>(table &Array<Opt<HashMapNode<K, V>>>, equator &E, startIndex int, key &K)
Opt<int>
where func(&E, &K, &K)bool, func drop(K)void, func drop(V)void {
  i = 0;
  while (i < table.len()) {
    index = (startIndex + i) mod table.len();
    // TSUGAR:     something = table[index];
    something = &table[__copy_prim(&index)];
    if (something.isEmpty()) {
      return None<int>();
    }
    node = something.get();
    // TSUGAR:     if ((&equator)(node.key, key)) {
    if ((&equator)(&node.key, key)) {
      return Some<int>(index);
    }
    // continue to next node
    set i = i + 1;
  }
  return panic("findIndexOfKey went past end of table! len " + str(table.len()) + " and i " + str(i));
}

func get<K Ref, V, H, E>(self &HashMap<K, V, H, E>, key &K) Opt<&V> {
  if ((&self.table).len() == 0) {
    return None<&V>();
  }
  hash int = (&self.hasher)(key);
  // TSUGAR:   startIndex = abs(hash mod (&self.table).len());
  startIndex = abs(&(hash mod (&self.table).len()));
  maybeIndex = findIndexOfKey(&self.table, &self.equator, startIndex, key);
  if ((&maybeIndex).isEmpty()) {
    opt Opt<&V> = None<&V>();
    return ^opt;
  }
  // TSUGAR:   node = self.table[maybeIndex.get()].get();
  node = (&(&self.table)[__copy_prim(&(^maybeIndex).get())]).get();
  opt Opt<&V> = Some<&V>(&node.value);
  return ^opt;
}

func has<K Ref, V, H, E>(self &HashMap<K, V, H, E>, key &K) bool {
  return not(self.get(key).isEmpty());
}

func keys<K Ref, V, H, E>(self &HashMap<K, V, H, E>) []K
where func clone(&K)K {
  list = List<K>();
  index = 0;
  while (index < (&self.table).len()) {
    // TSUGAR:     maybeNode = self.table[index];
    maybeNode = &(&self.table)[__copy_prim(&index)];
    if (not((&maybeNode).isEmpty())) {
      // TSUGAR:       list.add(maybeNode.get().key);
      (&list).add(clone(&(&maybeNode).get().key));
    }
    set index = index + 1;
  }
  [arr] = ^list;
  return ^arr;
}

func values<K Ref, V, H, E>(self &HashMap<K, V, H, E>) []&V {
  list = List<&V>();
  index = 0;
  while (index < (&self.table).len()) {
    // TSUGAR:     maybeNode = self.table[index];
    maybeNode = &(&self.table)[__copy_prim(&index)];
    if (not((&maybeNode).isEmpty())) {
      (&list).add(&(&maybeNode).get().value);
    }
    set index = index + 1;
  }
  [arr] = ^list;
  return ^arr;
}

func innerRemove<K Ref, V, H, E>(
  table &Array<Opt<HashMapNode<K, V>>>,
  hasher &H,
  equator &E,
  key K)
(int, V)
where func(&H, &K)int, func(&E, &K, &K)bool, func drop(K)void, func drop(V)void
{
  hash int = (&hasher)(&key);
  // TSUGAR:   startIndex = abs(hash mod table.len());
  startIndex = abs(&(hash mod table.len()));
  maybeIndex = findIndexOfKey(&table, equator, startIndex, &key);
  index = (^maybeIndex).get();
  // TSUGAR:   [unused, oldElement] = (set table[index] = None<HashMapNode<K, V>>()).get();
  [unused, oldElement] = (set table[__copy_prim(&index)] = None<HashMapNode<K, V>>()).get();
  // TSUGAR:   return (index, oldElement);
  return (__copy_prim(&index), ^oldElement);
}

func remove<K Ref, V, H, E>(
  map &HashMap<K, V, H, E>,
  key K)
V {
  [originalIndex, oldElement] = ^innerRemove(&map.table, &map.hasher, &map.equator, ^key);
  set map.size = map.size - 1;

  i = 1;
  while (i < (&map.table).len()) {
    neighborIndex = (originalIndex + i) mod len(&map.table);
    // TSUGAR:     maybeNeighbor = (set map.table[neighborIndex] = None<HashMapNode<K, V>>());
    maybeNeighbor = (set map.table[__copy_prim(&neighborIndex)] = None<HashMapNode<K, V>>());
    if (not (&maybeNeighbor).isEmpty()) {
      [neighborKey, neighborValue] = ^(^maybeNeighbor).get();
      addNodeToTable(&map.table, &map.hasher, HashMapNode<K, V>(^neighborKey, ^neighborValue));
    } else {
      drop((^maybeNeighbor).expect_none());
      set i = (&map.table).len(); // break
    }
    set i = i + 1;
  }

  return ^oldElement;
}
