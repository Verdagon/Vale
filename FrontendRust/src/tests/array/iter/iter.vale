
struct StaticSizedArrayReadonlyIter<N Int, E> where E Ref {
  arr &[#N]E;
  pos int;
}
func begin<N Int, E>(arr &[#N]E)
StaticSizedArrayReadonlyIter<N, E> {
  StaticSizedArrayReadonlyIter<N, E>(arr, 0)
}
func next<N Int, E>(iter &StaticSizedArrayReadonlyIter<N, E>) Opt<&E> {
  if iter.pos < iter.arr.len() {
    Some<&E>(&iter.arr[set iter.pos = iter.pos + 1])
  } else {
    None<&E>()
  }
}
