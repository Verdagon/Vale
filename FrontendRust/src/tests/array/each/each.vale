
func each<N Int, T, F>(arr &[#N]T, func &F) void
where func(&F,&T)void {
  i = 0;
  l = len(&arr);
  while (i < l) {
    // TSUGAR:     func(arr[i]);
    func(&arr[__copy_prim(&i)]);
    set i = i + 1;
  }
}

func eachI<N Int, T, F>(arr &[#N]T, func F) void
where func drop(F)void, func(&F,int,&T)void {
  i = 0;
  l = len(&arr);
  while (i < l) {
    // TSUGAR:     func(i, arr[i]);
    func(__copy_prim(&i), &arr[__copy_prim(&i)]);
    set i = i + 1;
  }
}

func each<T, F>(arr &[]T, func F) void
where func drop(F)void, func(&F,&T)void {
  i = 0;
  l = len(&arr);
  while (i < l) {
    // TSUGAR:     func(arr[i]);
    func(&arr[__copy_prim(&i)]);
    set i = i + 1;
  }
}

func eachI<F, T>(arr &[]T, func F) void
where func drop(F)void, func(&F,int,&T)void {
  i = 0;
  l = len(&arr);
  while (i < l) {
    // TSUGAR:     func(i, arr[i]);
    func(__copy_prim(&i), &arr[__copy_prim(&i)]);
    set i = i + 1;
  }
}
