
func MakeArray<T Ref, G Ref>(n int, generator G)
[]T
where func(&G, int)T, func drop(G)void
{
  // TSUGAR:   arr = Array<T>(n);
  arr = Array<T>(__copy_prim(&n));
  i = 0;
  while (i < n) {
    // TSUGAR:     arr.push(generator(i));
    (&arr).push(generator(__copy_prim(&i)));
    set i = i + 1;
  }
  return ^arr;
}
