
func has<E, F>(arr &[]E, elem &E, equator &F) bool
where func(&F, &E, &E)bool {
  i = 0;
  while (i < arr.len()) {
    // TSUGAR:     if (equator(arr[i], elem)) {
    if (equator(&arr[__copy_prim(&i)], elem)) {
      return true;
    }
    set i = i + 1;
  }
  return false;
}

func has<E>(arr &[]E, elem &E) bool
where func ==(&E, &E)bool {
  has(arr, elem, &{ _ == _ })
}

func has<E, F, N Int>(seq &[#N]E, elem &E, equator &F) bool
where func(&F, &E, &E)bool {
  i = 0;
  while (i < seq.len()) {
    // TSUGAR:     if (equator(seq[i], elem)) {
    if (equator(&seq[__copy_prim(&i)], elem)) {
      return true;
    }
    set i = i + 1;
  }
  return false;
}

func has<E, N Int>(seq &[#N]E, elem &E) bool
where func ==(&E, &E)bool {
  return has(seq, elem, &{ _ == _ });
}
