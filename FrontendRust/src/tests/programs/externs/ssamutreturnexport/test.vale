
export [#3]int as MutIntArray;

exported func valeMakeSSA() [#3]int {
  return [#](13, 14, 15);
}

extern func cMakeSSA() [#3]int;

exported func main() int {
  arr = cMakeSSA();
  i = 0;
  total = 0;
  while (i < arr.len()) {
    // TSUGAR:     set total = total + arr[i];
    set total = total + arr[__copy_prim(i)];
    set i = i + 1;
  }
  return total;
}
