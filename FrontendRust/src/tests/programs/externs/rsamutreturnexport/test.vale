
export []int as MutIntArray;

exported func valeMakeRSA() []int {
  ssa = [#](5, 7, 9, 10, 11);
  // TSUGAR:   return Array<int>(ssa.len(), { ssa[_] });
  return Array<int>(ssa.len(), { __copy_prim(ssa[_]) });
}

extern func cMakeRSA() []int;

exported func main() int {
  arr = cMakeRSA();
  i = 0;
  total = 0;
  while (i < arr.len()) {
    // TSUGAR:     set total = total + arr[i];
    set total = total + arr[__copy_prim(i)];
    set i = i + 1;
  }
  return total;
}
