
// TSUGAR: func round(num float) int {
// TSUGAR:   distanceToLower = num - float(int(num));
// TSUGAR:   return int(num) + if (distanceToLower < 0.5) { 0 } else { 1 };
// TSUGAR: }
func round(num float) int {
  truncated = int(&num);
  distanceToLower = num - float(&truncated);
  return truncated + if (distanceToLower < 0.5) { 0 } else { 1 };
}

exported func main() int {
  return round(7.9);
}
