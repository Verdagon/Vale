struct Thing {
  v Vec3i;
}

struct Vec3i share {
  x int;
  y int;
  z int;
}

func bork(thing &Thing, v Vec3i) void {
  set thing.v = v;
}

exported func main() int {
  thing = Thing(Vec3i(7, 8, 9));
  bork(&thing, Vec3i(4, 5, 6));
  // TSUGAR:   return thing.v.y;
  return __copy_prim(thing.v.y);
}
