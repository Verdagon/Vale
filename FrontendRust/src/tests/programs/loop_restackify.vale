import v.builtins.arith.*;
struct Spaceship { fuel int; }
func foo(ship Spaceship) Spaceship {
  // TSUGAR:   set ship.fuel = ship.fuel + 5;
  set ship.fuel = __copy_prim(&ship.fuel) + 5;
  return ^ship;
}
exported func main() int {
  ship = Spaceship(27);
  i = 0;
  // TSUGAR:   while i < 3 {
  while __copy_prim(&i) < 3 {
    set ship = foo(^ship);
    // TSUGAR:     set i = i + 1;
    set i = __copy_prim(&i) + 1;
  }
  [x] = ^ship;
  return ^x;
}
