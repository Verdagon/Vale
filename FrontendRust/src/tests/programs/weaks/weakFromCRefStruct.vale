
weakable struct Muta { hp int; }
exported func main() int {
  ownMuta = Muta(7);
  // TSUGAR:   print(str(ownMuta.hp));
  print(&str(__copy_prim(ownMuta.hp)));
  weakMuta = &&(&ownMuta);
  maybeBorrowMuta = lock(weakMuta);
  // TSUGAR:   return maybeBorrowMuta.get().hp;
  return __copy_prim(maybeBorrowMuta.get().hp);
}