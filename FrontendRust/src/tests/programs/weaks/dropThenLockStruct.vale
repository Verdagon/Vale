
weakable struct Muta { hp int; }
exported func main() int {
  ownMuta = Muta(73);
  weakMuta = &&ownMuta;
  drop(^ownMuta);
  maybeBorrowMuta = lock(weakMuta);
  return if maybeBorrowMuta.isEmpty() {
      42
    } else {
      // TSUGAR:       maybeBorrowMuta.get().hp
      __copy_prim(maybeBorrowMuta.get().hp)
    };
}