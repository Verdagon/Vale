import v.builtins.print.*;
import v.builtins.str.*;
import castutils.*;

func println(s str) void {
  print(&(s + "\n"));
}

func println(i int) void {
  print(&(str(i) + "\n"));
}

func println(b bool) void {
  print(&(str(b) + "\n"));
}

func println(f float) void {
  print(&(str(f) + "\n"));
}

func print(i int) void {
  print(&str(i));
}

func print(b bool) void {
  print(&str(b));
}

func print(f float) void {
  print(&str(f));
}

// VCOORD: this all should go away at some point
// Borrow-taking overloads so generic `where func print(&E)void` constraints can
// resolve when E is a primitive (e.g. listprintutils.vale's println).
func print(i &int) void {
  print(&str(__copy_prim(i)));
}

func print(b &bool) void {
  print(&str(__copy_prim(b)));
}

func print(f &float) void {
  print(&str(__copy_prim(f)));
}
// /VCOORD
