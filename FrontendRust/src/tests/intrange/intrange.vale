// TSUGAR: func range(begin int, end int) IntRange { return IntRange(begin, end); }
func range(begin &int, end &int) IntRange { return IntRange(__copy_prim(begin), __copy_prim(end)); }
struct IntRange { begin int; end int; }
// TSUGAR: func begin(self &IntRange) IntRangeIter { return IntRangeIter(self, self.begin); }
func begin(self &IntRange) IntRangeIter { return IntRangeIter(self, __copy_prim(self.begin)); }
struct IntRangeIter { range &IntRange; i int; }
func next(self &IntRangeIter) Opt<int> {
  if self.i < self.range.end {
    // TSUGAR:     Some(set self.i = self.i + 1)
    Some(__copy_prim(set self.i = self.i + 1))
  } else {
    None<int>()
  }
}
