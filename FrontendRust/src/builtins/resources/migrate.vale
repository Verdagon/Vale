import v.builtins.implicit_clone.*;
import v.builtins.arrays.*;

func migrate<E>(from []E, to &[]E) {
  intermediate = Array<E>((&from).capacity());
  drop_into(^from, &{ (&intermediate).push(^_); });
  drop_into(^intermediate, &{ to.push(^_); });
}

func migrate<E, N Int>(from [#N]E, to &[]E) {
  intermediate = Array<E>(N);
  drop_into(^from, &{ (&intermediate).push(^_); });
  drop_into(^intermediate, &{ to.push(^_); });
}
